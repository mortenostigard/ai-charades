{
  "name": "ai-charades-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "pnpm --filter @ai-charades/frontend dev",
    "dev:backend": "pnpm --filter @ai-charades/backend dev",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter @ai-charades/frontend build",
    "build:backend": "pnpm --filter @ai-charades/backend build",
    "build:shared": "pnpm --filter @ai-charades/shared build",
    "start:frontend": "pnpm --filter @ai-charades/frontend start",
    "start:backend": "pnpm --filter @ai-charades/backend start",
    "lint": "pnpm -r --if-present lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "pnpm -r type-check",
    "prepare": "husky"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
